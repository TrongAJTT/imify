{
  "name": "@imify/engine",
  "version": "0.0.1",
  "private": true,
  "description": "Image processing pipeline, WASM encoders, and worker pool for Imify",
  "scripts": {
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./converter": "./src/converter/index.ts",
    "./converter/*": "./src/converter/*.ts",
    "./custom-formats": "./src/custom-formats/index.ts",
    "./custom-formats/*": "./src/custom-formats/*.ts",
    "./image-pipeline/decode-image-data": "./src/image-pipeline/decode-image-data.ts",
    "./image-pipeline/render-image-data": "./src/image-pipeline/render-image-data.ts",
    "./image-pipeline/*": "./src/image-pipeline/*.ts"
  },
  "license": "Apache-2.0"
}
