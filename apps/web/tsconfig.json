{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@imify/core/*": [
        "../../packages/core/src/*"
      ],
      "@imify/engine/*": [
        "../../packages/engine/src/*"
      ],
      "@imify/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@imify/features/*": [
        "../../packages/features/src/*"
      ],
      "@imify/stores/*": [
        "../../packages/stores/src/*"
      ],
      "@imify/core": [
        "../../packages/core/src/index.ts"
      ],
      "@imify/engine": [
        "../../packages/engine/src/index.ts"
      ],
      "@imify/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@imify/features": [
        "../../packages/features/src/index.ts"
      ],
      "@imify/stores": [
        "../../packages/stores/src/index.ts"
      ]
    },
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
