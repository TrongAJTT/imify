{
  "name": "@imify/web",
  "version": "2.1.3",
  "displayName": "Imify - Powerful Image Toolkit",
  "versionType": "Stable",
  "author": "TrongAJTT <trong.ajtt.dev@gmail.com>",
  "private": true,
  "description": "A privacy-first, powerful image toolkit. Save image directly from your context menu, and even more. Supports ICO, AVIF, JPEG XL.",
  "scripts": {
    "check:media-assets": "node ../../scripts/check-media-asset-paths.mjs",
    "sync:features": "node ../../scripts/sync-shared-assets.mjs",
    "sync:assets": "pnpm sync:features && pnpm check:media-assets",
    "dev": "node ../../scripts/with-root-metadata.mjs next dev",
    "build": "node ../../scripts/with-root-metadata.mjs next build",
    "start": "node ../../scripts/with-root-metadata.mjs next start",
    "lint": "next lint",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@imify/core": "workspace:*",
    "@imify/engine": "workspace:*",
    "@imify/features": "workspace:*",
    "@imify/stores": "workspace:*",
    "@imify/ui": "workspace:*",
    "konva": "^10.2.5",
    "next": "^15.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-konva": "^19.2.3",
    "react-player": "^3.4.0",
    "youtube-video-element": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  }
}
