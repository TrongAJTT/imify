{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules",
    "src/features/converter/pdf-engine.ts"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./assets/*"],
      "~*": ["./*"],
      "@imify/core/*": ["../../packages/core/src/*"],
      "@imify/engine/*": ["../../packages/engine/src/*"],
      "@imify/ui/*": ["../../packages/ui/src/*"],
      "@imify/features/*": ["../../packages/features/src/*"],
      "@imify/stores/*": ["../../packages/stores/src/*"],
      "@imify/core": ["../../packages/core/src/index.ts"],
      "@imify/engine": ["../../packages/engine/src/index.ts"],
      "@imify/ui": ["../../packages/ui/src/index.ts"],
      "@imify/features": ["../../packages/features/src/index.ts"],
      "@imify/stores": ["../../packages/stores/src/index.ts"]
    },
    "types": [
      "chrome",
      "node"
    ]
  }
}
