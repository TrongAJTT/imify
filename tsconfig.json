{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules",
    "src/features/converter/pdf-engine.ts"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./assets/*"
      ],
      "~*": [
        "./*"
      ]
    },
    "types": [
      "chrome",
      "node"
    ]
  }
}
